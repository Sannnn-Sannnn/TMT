generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Period {
  today
  week
  month
}

model User {
  id       Int      @id @default(autoincrement())
  email    String   @unique
  password String
  //name     String
  tasks    Task[]
  timers   Timer[]
}

model Task {
  id          Int @id @default(autoincrement())
  description String
  createdAt   DateTime @default(now())
  dueFor      DateTime
  period      Period
  done        Boolean @default(false)

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
}

model Timer {
  id             Int @id @default(autoincrement())
  label          String
  intervalLength Int
  breakLength    Int
  totalIntervals Int
  autoStart      Boolean @default(true)

  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId Int
}